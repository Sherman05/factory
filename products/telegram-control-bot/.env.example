# Token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram user_id (get it from @userinfobot). Numeric.
# Only this chat_id is allowed to use /ping, /new and will receive /notify messages.
TELEGRAM_OWNER_CHAT_ID=

# HTTP port for POST /notify endpoint
HTTP_PORT=8080

# Absolute path to the factory git working copy (the checkout that /new commits into).
FACTORY_REPO_ROOT=

# GitHub "owner/repo" slug used to render links in /new replies and watched by the PR watcher.
GITHUB_REPO_SLUG=Sherman05/factory

# GitHub Personal Access Token (classic) with `repo` scope.
# Generate at https://github.com/settings/tokens. Used by the PR watcher.
GITHUB_TOKEN=

# PR watcher polling interval in milliseconds (default 120000 = 2 min).
POLL_INTERVAL_MS=120000

# --- Task worker (Brief F: /new → enqueue → runner) ---

# How often the worker checks the queue for a new task (ms). Default 2000.
WORKER_TICK_MS=2000

# Path to the `claude` CLI. Default "claude" (assumes it is on PATH).
# The worker spawns `claude -p "<orchestration prompt>"` inside a git worktree
# per task; it relies on the CLI's own logged-in session, not an API key.
CLAUDE_CLI_PATH=claude

# Where the SQLite task database lives. Default <FACTORY_REPO_ROOT>/.agent-factory/tasks.db.
# Directory is created automatically if missing; keep it inside .gitignore.
# TASK_DB_PATH=

# Where per-task git worktrees are created. Default <FACTORY_REPO_ROOT>/.worktrees.
# Each task gets <WORKTREES_ROOT>/task-<id> and branch run/task-<id>.
# WORKTREES_ROOT=
