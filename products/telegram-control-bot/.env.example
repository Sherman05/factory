# Token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram user_id (get it from @userinfobot). Numeric.
# Only this chat_id is allowed to use /ping, /new and will receive /notify messages.
TELEGRAM_OWNER_CHAT_ID=

# HTTP port for POST /notify endpoint
HTTP_PORT=8080

# Absolute path to the factory git working copy (the checkout that /new commits into).
FACTORY_REPO_ROOT=

# GitHub "owner/repo" slug used to render links in /new replies and watched by the PR watcher.
GITHUB_REPO_SLUG=Sherman05/factory

# GitHub Personal Access Token (classic) with `repo` scope.
# Generate at https://github.com/settings/tokens. Used by the PR watcher.
GITHUB_TOKEN=

# PR watcher polling interval in milliseconds (default 120000 = 2 min).
POLL_INTERVAL_MS=120000
